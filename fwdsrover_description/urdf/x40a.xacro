  <joint name="base_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 ${radians(-90)}"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <joint name="front_left_steering_joint" type="revolute">
    <origin xyz="-0.125 0.125 0.14" rpy="0.0 0.0 ${radians(0)}"/>
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="front_left_joint_1"/>
    <limit lower="-3.14159" upper="3.14159" effort="3.55" velocity="1.0"/>
    <dynamics damping="0.1"/>
  </joint>

  <joint name="front_left_sus_joint" type="prismatic">
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <axis xyz="0 0 1"/>
    <parent link="front_left_joint_1"/>
    <child link="front_left_sus_1"/>
    <limit lower="-0.0135" upper="0.0135" effort="300" velocity="1.0"/>
    <dynamics damping="522.3"/>
  </joint>

  <joint name="front_left_wheel_joint" type="continuous">
    <origin xyz="0.0 0.0 -0.07" rpy="0.0 0.0 0.0"/>
    <axis xyz="-1 0 0"/>
    <parent link="front_left_sus_1"/>
    <child link="front_left_wheel_1"/>
    <limit effort="10" velocity="50000"/>
    <dynamics damping="0.02"/>
  </joint>

